# --- Discord Configuration ---
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here
ALLOWED_ROLES=Admin,DevOps # Comma-separated list of role names allowed to run sensitive commands

# --- Bot Features ---
ENABLE_DOCKER=false # Set to true to enable /docker command group
POWER_CONTROL_ENABLED=false # Set to true to enable /power command group
POWER_CONTROL_PASSWORD=your_power_action_password_here

# --- WebUI Configuration ---
WEBUI_ENABLED=true
WEB_PASSWORD=your_web_access_password_here
SECRET_KEY=generate_a_random_security_token_here # Used for sessions and encryption
DATA_DIR=/app/data # Directory for config.json, audit.log, and known_hosts inside the container
TRUSTED_PROXY_IPS= # Optional comma-separated proxy IPs/CIDRs allowed to supply forwarded headers
WEBUI_SECURE_COOKIES=false # Set to true when serving the WebUI over HTTPS
OBSERVABILITY_REFRESH_MS=30000 # Dashboard refresh interval for overview cards; minimum effective value is 5000

# --- Server List (Numbered Format) ---
# You can add as many servers as you want by incrementing the number (1, 2, 3...)
# Optional per-server fields available in config.json/WebUI:
# - allowed_roles: comma-separated Discord roles allowed to manage that server
# - backup_path: remote file or directory used to calculate the "last backup age" card

# Server 1
DISCORD_UBUNTU_SERVER_ALIAS_1=server_1_alias
DISCORD_UBUNTU_SERVER_IP_1=server_1_host_or_ip
DISCORD_UBUNTU_SERVER_USER_1=ubuntu
DISCORD_UBUNTU_SERVER_AUTH_METHOD_1=key
# For 'key', you can provide the raw key string OR a file path inside the container:
DISCORD_UBUNTU_SERVER_KEY_1=/app/ssh_keys/example.key

# Server 2
DISCORD_UBUNTU_SERVER_ALIAS_2=server_2_alias
DISCORD_UBUNTU_SERVER_IP_2=server_2_host_or_ip
DISCORD_UBUNTU_SERVER_USER_2=admin
DISCORD_UBUNTU_SERVER_AUTH_METHOD_2=password
DISCORD_UBUNTU_SERVER_PASSWORD_2=your_secure_password_here

# --- Legacy Configuration (v0.1.0) ---
# SERVERS_JSON is still supported but individual variables above are preferred.
# SERVERS_JSON='[{"alias": "server_1_alias", "host": "server_1_host_or_ip", ...}]'

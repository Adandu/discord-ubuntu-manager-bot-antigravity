# --- Discord Configuration ---
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here

# --- Bot Features ---
ENABLE_DOCKER=false # Set to true to enable /docker command group

# --- Server List (JSON Format) ---
# Differentiate servers by "alias".
# "auth_method" can be "key" or "password".
# "secret_env" points to another environment variable name below.
SERVERS_JSON='[{"alias": "web-prod", "host": "1.2.3.4", "user": "ubuntu", "auth_method": "key", "secret_env": "SSH_KEY_PROD"}, {"alias": "db-01", "host": "10.0.0.5", "user": "admin", "auth_method": "password", "secret_env": "SSH_PASS_DB"}]'

# --- Actual Secrets (Mapped from SERVERS_JSON above) ---
# For 'key' auth, paste the ENTIRE private key content here (including BEGIN/END lines).
# For 'password' auth, paste the password here.
SSH_KEY_PROD="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
SSH_PASS_DB="your_secure_password_here"
